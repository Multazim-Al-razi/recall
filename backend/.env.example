# Recall backend configuration (copy to .env for local overrides)

# Port the API listens on.
PORT=21121

# Comma-separated list of allowed CORS origins for production, e.g.
# CORS_ORIGINS=https://recall.example.com,https://www.recall.example.com
# Leave unset in development to default to localhost.
CORS_ORIGINS=

# ── Supabase (see docs/BACKEND_ROADMAP.md) ────────────────────────────
# Set DB_BACKEND=supabase to route all reads/writes through Supabase
# Postgres instead of lowdb. Requires all three Supabase env vars below.
# Default: lowdb (dev-only, local JSON file).
DB_BACKEND=lowdb

# Supabase project URL (e.g. https://your-project-id.supabase.co)
SUPABASE_URL=

# Supabase anon key — used by the user-scoped client (RLS-protected).
SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS for admin/migration operations.
# NEVER expose this key to the browser or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# Set ALLOW_DEV_BACKEND=1 to bypass auth for local development only.
# NEVER set this to 1 in production — auth must always be enforced.
ALLOW_DEV_BACKEND=

# Comma-separated list of admin email addresses who can view cross-tenant
# aggregate stats. Regular authenticated users see only their own data.
ADMIN_EMAILS=
