# Recall frontend configuration (copy to .env for local overrides)

# Backend API URL — defaults to /api (same-origin proxy) if unset.
VITE_API_URL=/api

# ── Supabase (Workstream 1 — see docs/BACKEND_ROADMAP.md) ────────────
# Required when the app connects directly to Supabase for auth, realtime,
# or direct reads (anon key + RLS). The service role key is never used on
# the frontend — it lives in backend/.env only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
