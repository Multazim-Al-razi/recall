{
  "name": "recall",
  "private": true,
  "version": "1.0.1",
  "workspaces": [
    "frontend",
    "backend",
    "cli"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "lint": "npm run lint -w frontend",
    "preview": "npm run preview -w frontend",
    "test": "npm run test -w frontend && npm run test -w backend",
    "test:frontend": "npm run test -w frontend",
    "test:backend": "npm run test -w backend",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
